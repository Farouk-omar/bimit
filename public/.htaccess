# BIM IT — Apache / cPanel config for the built site.
# (Vite copies this to the deploy root, e.g. public_html/.htaccess)

# --- Single-page-app routing -------------------------------------------------
# React Router uses real URLs (/about, /services, ...). Apache must serve the
# SPA shell for those paths instead of returning 404. Real files (assets and
# /api/*.php) are served directly because of the -f / -d checks below.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.html [L]
</IfModule>

# --- Caching -----------------------------------------------------------------
# Build assets are content-hashed, so they can be cached forever. The HTML
# shell must never be cached, or visitors get stale asset references.
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|svg|png|jpg|jpeg|gif|ico|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

# --- Compression -------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
        application/javascript application/json image/svg+xml
</IfModule>
